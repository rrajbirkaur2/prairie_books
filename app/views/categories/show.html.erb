<div class="container mt-5">
  <div class="row">
    <div class="col-md-3">
      <div class="card p-3 shadow-sm">
        <h5 class="mb-3">📂 All Categories</h5>
        <ul class="list-unstyled mb-0">
          <% @categories.each do |cat| %>
            <li class="mb-2">
              <%= link_to category_path(cat), class: "text-decoration-none d-flex justify-content-between align-items-center" do %>
                <span class="<%= cat == @category ? 'fw-bold' : '' %>">📖 <%= cat.name %></span>
                <span class="badge bg-secondary"><%= cat.books.count %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
        <hr>
        <%= link_to "← All Books", books_path, class: "btn btn-outline-dark btn-sm w-100" %>
      </div>
    </div>

    <div class="col-md-9">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
          <li class="breadcrumb-item"><%= link_to "Books", books_path %></li>
          <li class="breadcrumb-item active"><%= @category.name %></li>
        </ol>
      </nav>

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="mb-1"><%= @category.name %></h2>
          <p class="text-muted mb-0"><%= @category.description %></p>
        </div>
        <span class="badge bg-secondary fs-6"><%= @books.total_count %> books</span>
      </div>

      <% if @books.empty? %>
        <div class="alert alert-info text-center py-5">
          <h4>No books in this category yet</h4>
          <%= link_to "Browse All Books", books_path, class: "btn btn-dark mt-2" %>
        </div>
      <% else %>
        <div class="row">
          <% @books.each do |book| %>
            <%= render 'shared/book_card', book: book %>
          <% end %>
        </div>
        <div class="d-flex justify-content-center mt-5">
          <%= paginate @books %>
        </div>
      <% end %>
    </div>
  </div>
</div>