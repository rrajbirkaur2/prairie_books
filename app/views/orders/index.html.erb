<div class="container mt-5">
  <h2>📦 My Orders</h2>
  <hr>

  <% if @orders.empty? %>
    <div class="alert alert-info text-center py-5">
      <h5>No orders yet</h5>
      <%= link_to "Start Shopping", books_path, class: "btn btn-dark mt-2" %>
    </div>
  <% else %>
    <% @orders.each do |order| %>
      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="fw-bold">Order #<%= order.id %></span>
          <span class="badge <%= order.status == 'paid' ? 'bg-success' : order.status == 'shipped' ? 'bg-info' : 'bg-warning text-dark' %>">
            <%= order.status.capitalize %>
          </span>
          <span class="text-muted small"><%= order.created_at.strftime("%B %d, %Y") %></span>
        </div>
        <div class="card-body">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Book</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% order.order_items.each do |item| %>
                <tr>
                  <td><%= item.book.title %></td>
                  <td><%= item.quantity %></td>
                  <td>$<%= number_with_precision(item.price_at_purchase, precision: 2) %></td>
                  <td>$<%= number_with_precision(item.subtotal, precision: 2) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <hr>
          <div class="row">
            <div class="col-md-6">
              <small class="text-muted">
                <strong>Ship to:</strong> <%= order.address %>, <%= order.city %>, <%= order.province&.name %> <%= order.postal_code %>
              </small>
            </div>
            <div class="col-md-6 text-end">
              <% if order.gst_amount.to_f > 0 %>
                <small class="text-muted d-block">GST: $<%= number_with_precision(order.gst_amount, precision: 2) %></small>
              <% end %>
              <% if order.pst_amount.to_f > 0 %>
                <small class="text-muted d-block">PST: $<%= number_with_precision(order.pst_amount, precision: 2) %></small>
              <% end %>
              <% if order.hst_amount.to_f > 0 %>
                <small class="text-muted d-block">HST: $<%= number_with_precision(order.hst_amount, precision: 2) %></small>
              <% end %>
              <strong class="text-warning fs-5">Total: $<%= number_with_precision(order.grand_total, precision: 2) %></strong>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>