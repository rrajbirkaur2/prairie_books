<div class="container mt-4">
  <%= render 'shared/breadcrumbs' %>
  <div class="row justify-content-center">
    <div class="col-md-10">
      <h3 class="mb-4">📋 Review Your Order</h3>

      <div class="row">
        <%# Left: Order items and address %>
        <div class="col-md-7">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
              <h5 class="mb-0">Order Items</h5>
            </div>
            <div class="card-body p-0">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Book</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Subtotal</th>
                  </tr>
                </thead>
                <tbody>
                  <% @cart_items.each do |item| %>
                    <tr>
                      <td>
                        <strong><%= item.book.title %></strong><br>
                        <small class="text-muted"><%= item.book.author %></small>
                      </td>
                      <td>$<%= number_with_precision(item.price_at_purchase, precision: 2) %></td>
                      <td><%= item.quantity %></td>
                      <td>$<%= number_with_precision(item.subtotal, precision: 2) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
              <h5 class="mb-0">Shipping Address</h5>
            </div>
            <div class="card-body">
              <p class="mb-1"><%= @address %></p>
              <p class="mb-1"><%= @city %></p>
              <p class="mb-1"><strong><%= @province.name %></strong></p>
              <p class="mb-0"><%= @postal_code %></p>
            </div>
          </div>
        </div>

        <%# Right: Order summary + Stripe %>
        <div class="col-md-5">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
              <h5 class="mb-0">Order Summary</h5>
            </div>
            <div class="card-body">
              <div class="d-flex justify-content-between mb-2">
                <span>Subtotal</span>
                <span>$<%= number_with_precision(@subtotal, precision: 2) %></span>
              </div>
              <% if @gst > 0 %>
                <div class="d-flex justify-content-between mb-2 text-muted small">
                  <span>GST (<%= number_with_precision(@province.gst * 100, precision: 1) %>%)</span>
                  <span>$<%= number_with_precision(@gst, precision: 2) %></span>
                </div>
              <% end %>
              <% if @pst > 0 %>
                <div class="d-flex justify-content-between mb-2 text-muted small">
                  <span>PST (<%= number_with_precision(@province.pst * 100, precision: 1) %>%)</span>
                  <span>$<%= number_with_precision(@pst, precision: 2) %></span>
                </div>
              <% end %>
              <% if @hst > 0 %>
                <div class="d-flex justify-content-between mb-2 text-muted small">
                  <span>HST (<%= number_with_precision(@province.hst * 100, precision: 1) %>%)</span>
                  <span>$<%= number_with_precision(@hst, precision: 2) %></span>
                </div>
              <% end %>
              <hr>
              <div class="d-flex justify-content-between fw-bold fs-5">
                <span>Total</span>
                <span class="text-warning">
                  $<%= number_with_precision(@grand_total, precision: 2) %>
                </span>
              </div>
            </div>
          </div>

          <%# Stripe payment form %>
          <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
              <h5 class="mb-0">💳 Pay with Card</h5>
            </div>
            <div class="card-body">
              <%= form_with url: complete_checkout_path,
                  method: :post,
                  local: true,
                  id: "payment-form" do |f| %>
                <div class="mb-3">
                  <label class="form-label fw-bold">Card Details</label>
                  <div id="card-element"
                       class="form-control"
                       style="padding: 12px; height: auto;">
                  </div>
                  <div id="card-errors" class="text-danger small mt-1"></div>
                </div>
                <small class="text-muted d-block mb-3">
                  🔒 Secured by Stripe<br>
                  <span class="text-success">Test card: 4242 4242 4242 4242 | 12/28 | 123</span>
                </small>
                <div class="d-grid gap-2">
                  <button type="submit"
                          class="btn btn-warning btn-lg fw-bold"
                          id="submit-button">
                    Pay $<%= number_with_precision(@grand_total, precision: 2) %> →
                  </button>
                  <%= link_to "← Back to Cart", cart_path,
                      class: "btn btn-outline-dark" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
  var stripe = Stripe('<%= @stripe_publishable_key %>');
  var elements = stripe.elements();

  var cardElement = elements.create('card', {
    style: {
      base: {
        fontSize: '16px',
        color: '#424770',
        fontFamily: 'Georgia, serif',
        '::placeholder': { color: '#aab7c4' }
      },
      invalid: { color: '#9e2146' }
    }
  });

  cardElement.mount('#card-element');

  cardElement.on('change', function(event) {
    var displayError = document.getElementById('card-errors');
    displayError.textContent = event.error ? event.error.message : '';
  });

  var form = document.getElementById('payment-form');
  var submitButton = document.getElementById('submit-button');

  form.addEventListener('submit', function(event) {
    event.preventDefault();
    submitButton.disabled = true;
    submitButton.textContent = 'Processing...';

    stripe.createToken(cardElement).then(function(result) {
      if (result.error) {
        document.getElementById('card-errors').textContent = result.error.message;
        submitButton.disabled = false;
        submitButton.textContent = 'Pay $<%= number_with_precision(@grand_total, precision: 2) %> →';
      } else {
        var hiddenInput = document.createElement('input');
        hiddenInput.setAttribute('type', 'hidden');
        hiddenInput.setAttribute('name', 'stripeToken');
        hiddenInput.setAttribute('value', result.token.id);
        form.appendChild(hiddenInput);
        form.submit();
      }
    });
  });
</script>