<div class="container mt-5">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Books", books_path %></li>
      <li class="breadcrumb-item"><%= link_to @book.category.name, category_path(@book.category) %></li>
      <li class="breadcrumb-item active"><%= @book.title %></li>
    </ol>
  </nav>

  <div class="row">
    <div class="col-md-4">
  <% if @book.cover_image.attached? %>
  <%= image_tag url_for(@book.cover_image),
      class: "img-fluid rounded shadow",
      alt: "Cover of #{@book.title}",
      style: "max-height: 450px; object-fit: cover;" %>
  <% elsif @book.cover_url.present? %>
    <%= image_tag @book.cover_url,
        class: "img-fluid rounded shadow",
        style: "max-height: 450px; object-fit: cover;",
        onerror: "this.style.display='none'; this.nextElementSibling.style.display='flex';" %>
    <div class="d-none align-items-center justify-content-center rounded"
         style="height: 350px; background: linear-gradient(135deg, #2c3e50, #3498db);">
      <div class="text-center text-white p-3">
        <div style="font-size: 3rem;">📖</div>
        <h5><%= @book.title %></h5>
        <p><%= @book.author %></p>
      </div>
    </div>
  <% else %>
    <div class="d-flex align-items-center justify-content-center rounded"
         style="height: 350px; background: linear-gradient(135deg, #2c3e50, #3498db);">
      <div class="text-center text-white p-3">
        <div style="font-size: 3rem;">📖</div>
        <h5><%= @book.title %></h5>
        <p><%= @book.author %></p>
      </div>
    </div>
  <% end %>
</div>
    <div class="col-md-8">
      <% if @book.on_sale? %>
        <span class="badge bg-warning text-dark fs-6 mb-2">🏷️ On Sale!</span>
      <% end %>
      <h1><%= @book.title %></h1>
      <p class="text-muted fs-5">by <%= @book.author %></p>
      <span class="badge bg-secondary mb-3"><%= @book.category.name %></span>
      <p class="fs-2 fw-bold text-warning">$<%= number_with_precision(@book.price, precision: 2) %></p>
      <p><%= @book.description %></p>
      <p>
        <% if @book.stock_quantity > 0 %>
          <span class="text-success fw-bold">✓ In Stock (<%= @book.stock_quantity %> available)</span>
        <% else %>
          <span class="text-danger fw-bold">✗ Out of Stock</span>
        <% end %>
      </p>
      <% if @book.stock_quantity > 0 %>
  <%= form_with url: cart_items_path(book_id: @book.id), method: :post, local: true do |f| %>
    <%= f.submit "Add to Cart 🛒", class: "btn btn-warning btn-lg" %>
  <% end %>
<% else %>
  <button class="btn btn-secondary btn-lg" disabled>Out of Stock</button>
<% end %>
    </div>
  </div>
</div>