<div class="container mt-4">
  <div class="row">

    <%# Left: Books grid %>
    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h3 class="mb-0">
            <% if params[:filter] == "on_sale" %>
              🏷️ On Sale
            <% elsif params[:filter] == "new" %>
              🆕 New Arrivals
            <% elsif params[:filter] == "recently_updated" %>
              🔄 Recently Updated
            <% elsif params[:search].present? && @selected_category %>
              Results for "<%= params[:search] %>" in <%= @selected_category.name %>
            <% elsif params[:search].present? %>
              Results for "<%= params[:search] %>"
            <% elsif @selected_category %>
              <%= @selected_category.name %>
            <% else %>
              All Books
            <% end %>
          </h3>
          <% if params[:search].present? || params[:category_id].present? %>
            <%= link_to "← Clear search", books_path, class: "small text-muted" %>
          <% end %>
        </div>
        <span class="badge bg-secondary"><%= @books.total_count %> books</span>
      </div>

      <% if @books.empty? %>
        <div class="alert alert-info text-center py-5">
          <h5>No books found</h5>
          <% if params[:search].present? && params[:category_id].present? %>
            <p>No results for "<%= params[:search] %>" in this category.</p>
            <%= link_to "Search all categories", books_path(search: params[:search]), class: "btn btn-outline-dark btn-sm me-2" %>
          <% end %>
          <%= link_to "View All Books", books_path, class: "btn btn-dark mt-2" %>
        </div>
      <% else %>
        <div class="row row-cols-2 row-cols-md-3 g-3">
          <% @books.each do |book| %>
            <%= render 'shared/book_card', book: book %>
          <% end %>
        </div>
        <div class="d-flex justify-content-center mt-4">
          <%= paginate @books %>
        </div>
      <% end %>
    </div>

    <%# Right sidebar %>
    <div class="col-md-3">

      <%# Search box on top of right sidebar %>
      <div class="card shadow-sm mb-3">
        <div class="card-header bg-dark text-white">
          <h6 class="mb-0">🔍 Search Books</h6>
        </div>
        <div class="card-body">
          <%= form_with url: books_path, method: :get, local: true do |f| %>
            <div class="mb-2">
              <%= f.text_field :search,
                  value: params[:search],
                  class: "form-control form-control-sm",
                  placeholder: "Search title or description..." %>
            </div>
            <div class="mb-2">
              <%= f.select :category_id,
                  options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
                  { include_blank: "All Categories" },
                  class: "form-select form-select-sm" %>
            </div>
            <div class="d-flex gap-1 mb-3">
              <%= f.submit "Search", class: "btn btn-dark btn-sm flex-grow-1" %>
              <%= link_to "Clear", books_path, class: "btn btn-outline-secondary btn-sm" %>
            </div>

            <%# Popular keywords %>
            <div>
              <small class="text-muted fw-bold d-block mb-1">Popular:</small>
              <div class="d-flex flex-wrap gap-1">
                <%= link_to "Harry Potter", books_path(search: "Harry Potter"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Mystery", books_path(search: "mystery"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Science", books_path(search: "science"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "History", books_path(search: "history"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Adventure", books_path(search: "adventure"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Love", books_path(search: "love"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "War", books_path(search: "war"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Biology", books_path(search: "biology"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Philosophy", books_path(search: "philosophy"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Mathematics", books_path(search: "mathematics"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Children", books_path(search: "children"), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Fiction", books_path(search: "fiction"), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Filter buttons %>
      <div class="card shadow-sm mb-3">
        <div class="card-header bg-dark text-white">
          <h6 class="mb-0">🎯 Filter Books</h6>
        </div>
        <div class="card-body p-2">
          <div class="d-grid gap-1">
            <%= link_to "📚 All Books", books_path,
                class: "btn btn-sm text-start #{params[:filter].blank? && params[:search].blank? && params[:category_id].blank? ? 'btn-dark' : 'btn-outline-dark'}" %>
            <%= link_to "🏷️ On Sale", books_path(filter: "on_sale"),
                class: "btn btn-sm text-start #{params[:filter] == 'on_sale' ? 'btn-warning' : 'btn-outline-warning'}" %>
            <%= link_to "🆕 New Arrivals", books_path(filter: "new"),
                class: "btn btn-sm text-start #{params[:filter] == 'new' ? 'btn-success' : 'btn-outline-success'}" %>
            <%= link_to "🔄 Recently Updated", books_path(filter: "recently_updated"),
                class: "btn btn-sm text-start #{params[:filter] == 'recently_updated' ? 'btn-info' : 'btn-outline-info'}" %>
          </div>
        </div>
      </div>

      <%# Browse by category %>
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
          <h6 class="mb-0">📂 Browse by Category</h6>
        </div>
        <div class="list-group list-group-flush">
          <%= link_to books_path(search: params[:search]),
              class: "list-group-item list-group-item-action small d-flex justify-content-between #{params[:category_id].blank? ? 'active' : ''}" do %>
            All Categories
            <span class="badge bg-secondary"><%= Book.count %></span>
          <% end %>
          <% @categories.each do |category| %>
            <%= link_to books_path(search: params[:search], category_id: category.id),
                class: "list-group-item list-group-item-action small d-flex justify-content-between #{params[:category_id].to_s == category.id.to_s ? 'active' : ''}" do %>
              <%= category.name %>
              <span class="badge bg-secondary"><%= category.books.count %></span>
            <% end %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>