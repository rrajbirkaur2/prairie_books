<div class="container mt-4">
<div class="mb-4">
  <h6 class="text-muted mb-2">Popular Searches:</h6>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Harry Potter", books_path(search: "Harry Potter"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Mystery", books_path(search: "mystery"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Science", books_path(search: "science"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "History", books_path(search: "history"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Adventure", books_path(search: "adventure"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Love", books_path(search: "love"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "War", books_path(search: "war"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Biology", books_path(search: "biology"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Fiction", books_path(search: "fiction"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Mathematics", books_path(search: "mathematics"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Philosophy", books_path(search: "philosophy"), class: "btn btn-outline-dark btn-sm" %>
    <%= link_to "Children", books_path(search: "children"), class: "btn btn-outline-dark btn-sm" %>
  </div>
</div>
  <div class="row">

    <%# Left: Books grid %>
    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">
          <% if params[:filter] == "on_sale" %>
            🏷️ On Sale
          <% elsif params[:filter] == "new" %>
            🆕 New Arrivals
          <% elsif params[:filter] == "recently_updated" %>
            🔄 Recently Updated
          <% elsif params[:search].present? %>
            Search: "<%= params[:search] %>"
          <% else %>
            All Books
          <% end %>
        </h3>
        <span class="badge bg-secondary"><%= @books.total_count %> books</span>
      </div>

      <% if @books.empty? %>
        <div class="alert alert-info text-center py-5">
          <h5>No books found</h5>
          <%= link_to "View All Books", books_path, class: "btn btn-dark mt-2" %>
        </div>
      <% else %>
        <div class="row row-cols-2 row-cols-md-3 g-3">
          <% @books.each do |book| %>
            <%= render 'shared/book_card', book: book %>
          <% end %>
        </div>
        <div class="d-flex justify-content-center mt-4">
          <%= paginate @books %>
        </div>
      <% end %>
    </div>

    <%# Right: Filter sidebar only %>
    <div class="col-md-3">
      <div class="card shadow-sm mb-3">
        <div class="card-header bg-dark text-white">
          <h6 class="mb-0">🎯 Filter Books</h6>
        </div>
        <div class="card-body p-2">
          <div class="d-grid gap-1">
            <%= link_to "📚 All Books", books_path,
                class: "btn btn-sm text-start #{params[:filter].blank? && params[:search].blank? ? 'btn-dark' : 'btn-outline-dark'}" %>
            <%= link_to "🏷️ On Sale", books_path(filter: "on_sale"),
                class: "btn btn-sm text-start #{params[:filter] == 'on_sale' ? 'btn-warning' : 'btn-outline-warning'}" %>
            <%= link_to "🆕 New Arrivals", books_path(filter: "new"),
                class: "btn btn-sm text-start #{params[:filter] == 'new' ? 'btn-success' : 'btn-outline-success'}" %>
            <%= link_to "🔄 Recently Updated", books_path(filter: "recently_updated"),
                class: "btn btn-sm text-start #{params[:filter] == 'recently_updated' ? 'btn-info' : 'btn-outline-info'}" %>
          </div>
        </div>
      </div>

      <%# Quick category links %>
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
          <h6 class="mb-0">📂 Categories</h6>
        </div>
        <div class="list-group list-group-flush">
          <%= link_to "All Books", books_path,
              class: "list-group-item list-group-item-action small #{params[:category_id].blank? ? 'active' : ''}" %>
          <% @categories.each do |category| %>
            <%= link_to category_path(category),
                class: "list-group-item list-group-item-action small d-flex justify-content-between" do %>
              <%= category.name %>
              <span class="badge bg-secondary"><%= category.books.count %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>