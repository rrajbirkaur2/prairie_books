<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">Create Account</h4>
        </div>
        <div class="card-body">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

            <% if resource.errors.any? %>
              <div class="alert alert-danger">
                <% resource.errors.full_messages.each do |msg| %>
                  <p class="mb-0"><%= msg %></p>
                <% end %>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :name, class: "form-label fw-bold" %>
              <%= f.text_field :name, class: "form-control", placeholder: "Your full name", autofocus: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-bold" %>
              <%= f.email_field :email, class: "form-control", placeholder: "Email address" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-bold" %>
              <%= f.password_field :password, class: "form-control", placeholder: "Password (min 6 characters)" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, class: "form-label fw-bold" %>
              <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm password" %>
            </div>

            <hr>
            <h6 class="fw-bold text-muted mb-3">Address Details (Optional)</h6>

            <div class="mb-3">
              <%= f.label :address, "Street Address", class: "form-label fw-bold" %>
              <%= f.text_field :address, class: "form-control", placeholder: "123 Main Street" %>
            </div>

            <div class="mb-3">
              <%= f.label :city, class: "form-label fw-bold" %>
              <%= f.text_field :city, class: "form-control", placeholder: "Winnipeg" %>
            </div>

            <div class="mb-3">
              <%= f.label :province_id, "Province", class: "form-label fw-bold" %>
              <%= f.select :province_id,
                  options_from_collection_for_select(Province.all, :id, :name, f.object.province_id),
                  { include_blank: "Select your province" },
                  class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :postal_code, class: "form-label fw-bold" %>
              <%= f.text_field :postal_code, class: "form-control", placeholder: "R3C 1A1" %>
            </div>

            <div class="d-grid">
              <%= f.submit "Create Account", class: "btn btn-dark btn-lg" %>
            </div>

          <% end %>

          <div class="text-center mt-3">
            <p>Already have an account? <%= link_to "Sign In", new_user_session_path %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>