<div class="col mb-4">
  <div class="card book-card h-100 shadow-sm">
    <%= link_to book_path(book), class: "text-decoration-none" do %>
      <div style="height: 200px; overflow: hidden; background: linear-gradient(135deg, #2c3e50, #3498db); border-radius: 8px 8px 0 0;">
        <% if book.cover_image.attached? %>
          <%= image_tag url_for(book.cover_image),
              alt: "Cover of #{book.title}",
              style: "width: 100%; height: 200px; object-fit: cover;" %>
        <% elsif book.cover_url.present? %>
          <img src="<%= book.cover_url %>"
               alt="Cover of <%= book.title %>"
               style="width: 100%; height: 200px; object-fit: cover;"
               onerror="this.style.display='none';">
        <% else %>
          <div class="d-flex align-items-center justify-content-center h-100">
            <div class="text-center text-white p-2">
              <div style="font-size: 2rem;">📖</div>
              <small class="fw-bold d-block" style="font-size: 0.75rem;">
                <%= book.title.truncate(30) %>
              </small>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
    <div class="card-body d-flex flex-column p-3">
      <p class="card-title fw-bold mb-1" style="font-size: 0.9rem; min-height: 2.5rem;">
        <%= book.title.truncate(40) %>
      </p>
      <p class="text-muted mb-1" style="font-size: 0.8rem;">
        <%= book.author.truncate(30) %>
      </p>
      <p class="text-muted mb-2" style="font-size: 0.78rem; min-height: 3rem;">
        <%= truncate(book.description, length: 70) %>
      </p>
      <div class="mt-auto">
        <% if book.on_sale? %>
          <span class="badge bg-warning text-dark mb-1" style="font-size: 0.7rem;">
            🏷️ On Sale!
          </span>
        <% end %>
        <p class="price mb-2 fw-bold" style="font-size: 1rem; color: #e67e22;">
          $<%= number_with_precision(book.price, precision: 2) %>
        </p>
        <%= link_to "View Details", book_path(book),
            class: "btn btn-outline-dark btn-sm w-100" %>
      </div>
    </div>
  </div>
</div>