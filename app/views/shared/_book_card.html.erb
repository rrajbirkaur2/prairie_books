<div class="col-md-3 mb-4">
  <div class="card book-card h-100">
    <% if book.cover_image.attached? %>
      <%= image_tag url_for(book.cover_image), class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
    <% else %>
      <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 200px;">
        <span style="font-size: 4rem;">📚</span>
      </div>
    <% end %>
    <div class="card-body d-flex flex-column">
      <h6 class="card-title"><%= book.title %></h6>
      <p class="card-text text-muted small"><%= book.author %></p>
      <p class="card-text small"><%= truncate(book.description, length: 80) %></p>
      <div class="mt-auto">
        <% if book.on_sale? %>
          <span class="badge bg-warning text-dark mb-1">On Sale!</span>
        <% end %>
        <p class="price mb-2">$<%= number_with_precision(book.price, precision: 2) %></p>
        <%= link_to "View Details", book_path(book), class: "btn btn-outline-dark btn-sm w-100" %>
      </div>
    </div>
  </div>
</div>