<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container-fluid px-4">
    <%= link_to "Prairie Books", root_path, class: "navbar-brand" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">

      <%# Left nav links %>
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "Books", books_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "Categories", categories_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "About", about_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "Contact", contact_path, class: "nav-link" %></li>
      </ul>

      <%# Right side: stacked %>
      <div class="d-flex flex-column align-items-end gap-1">

        <%# Row 1: Search box, then category filter, then Search button %>
        <%= form_with url: books_path, method: :get, local: true, class: "d-flex align-items-center gap-1" do |f| %>
          <%= f.text_field :search,
              value: params[:search],
              class: "form-control form-control-sm",
              placeholder: "Search books...",
              style: "width: 160px;" %>
          <%= f.select :category_id,
              options_from_collection_for_select(Category.all, :id, :name, params[:category_id]),
              { include_blank: "All Categories" },
              class: "form-select form-select-sm",
              style: "width: 140px;" %>
          <%= f.submit "Search", class: "btn btn-warning btn-sm" %>
        <% end %>

        <%# Row 2: Sign In, Sign Up, Cart %>
        <div class="d-flex align-items-center gap-2">
          <% if user_signed_in? %>
            <span class="text-white-50 small">Hi, <%= current_user.name %></span>
            <%= link_to "Sign Out", destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "btn btn-outline-light btn-sm" %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-light btn-sm" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-warning btn-sm" %>
          <% end %>
          <%= link_to cart_path, class: "btn btn-outline-light btn-sm" do %>
            🛒 Cart
            <% cart_count = current_cart.total_items %>
            <% if cart_count > 0 %>
              <span class="badge bg-warning text-dark"><%= cart_count %></span>
            <% end %>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</nav>