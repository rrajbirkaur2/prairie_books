<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <%= link_to "Prairie Books", root_path, class: "navbar-brand" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <%= link_to "Home", root_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Books", books_path, class: "nav-link" %>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            Categories
          </a>
          <ul class="dropdown-menu">
            <% Category.all.each do |category| %>
              <li><%= link_to category.name, category_path(category), class: "dropdown-item" %></li>
            <% end %>
          </ul>
        </li>
        <li class="nav-item">
          <%= link_to "About", about_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Contact", contact_path, class: "nav-link" %>
        </li>
      </ul>
      <ul class="navbar-nav ms-auto align-items-center">
        <% if user_signed_in? %>
          <li class="nav-item">
            <span class="nav-link text-white-50">Hi, <%= current_user.name %></span>
          </li>
          <li class="nav-item">
            <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-warning btn-sm ms-2" %>
          </li>
        <% end %>
        <li class="nav-item ms-3">
          <%= link_to cart_path, class: "btn btn-outline-light btn-sm" do %>
            🛒 Cart
            <% cart_count = current_cart.total_items %>
            <% if cart_count > 0 %>
              <span class="badge bg-warning text-dark"><%= cart_count %></span>
            <% end %>
          <% end %>
        </li>
      </ul>
    </div>
  </div>
</nav>