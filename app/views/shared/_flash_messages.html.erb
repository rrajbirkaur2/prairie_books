<% flash.each do |type, message| %>
  <% alert_class = type.to_s == "notice" ? "success" : "danger" %>
  <div class="alert alert-<%= alert_class %> alert-dismissible fade show mb-0" role="alert">
    <div class="container">
      <strong><%= type.to_s == "notice" ? "✓" : "✗" %></strong>
      <%= message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  </div>
<% end %>

<script>
  setTimeout(function() {
    document.querySelectorAll('.alert').forEach(function(alert) {
      alert.style.display = 'none';
    });
  }, 4000);
</script>