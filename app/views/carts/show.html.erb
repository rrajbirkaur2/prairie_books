<div class="container mt-5">
  <h2>🛒 Your Shopping Cart</h2>
  <hr>

  <% if @cart.cart_items.empty? %>
    <div class="alert alert-info text-center py-5">
      <h4>Your cart is empty!</h4>
      <p>Browse our collection and add some books.</p>
      <%= link_to "Browse Books", books_path, class: "btn btn-dark mt-2" %>
    </div>
  <% else %>
    <div class="row">
      <div class="col-md-8">
        <div class="card shadow-sm">
          <div class="card-body p-0">
            <table class="table table-hover mb-0">
              <thead class="table-dark">
                <tr>
                  <th>Book</th>
                  <th>Price</th>
                  <th>Quantity</th>
                  <th>Subtotal</th>
                  <th>Remove</th>
                </tr>
              </thead>
              <tbody>
                <% @cart.cart_items.each do |item| %>
                  <tr>
                    <td>
  <div class="d-flex align-items-center">
    <% if item.book.cover_image.attached? %>
      <%= image_tag url_for(item.book.cover_image),
          style: "height: 60px; width: 45px; object-fit: cover; border-radius: 4px;",
          class: "me-3" %>
    <% elsif item.book.cover_url.present? %>
      <%= image_tag item.book.cover_url,
          style: "height: 60px; width: 45px; object-fit: cover; border-radius: 4px;",
          class: "me-3",
          onerror: "this.style.display='none'" %>
    <% else %>
      <div class="me-3 d-flex align-items-center justify-content-center"
           style="height: 60px; width: 45px; background: linear-gradient(135deg, #2c3e50, #3498db); border-radius: 4px;">
        <span style="font-size: 1.2rem;">📖</span>
      </div>
    <% end %>
    <div>
      <%= link_to item.book.title, book_path(item.book),
          class: "text-decoration-none fw-bold" %>
      <br>
      <small class="text-muted"><%= item.book.author %></small>
    </div>
  </div>
</td>
                    <td>$<%= number_with_precision(item.price_at_purchase, precision: 2) %></td>
                    <td style="width: 180px;">
                      <%= form_with url: cart_item_path(item), method: :patch, local: true do |f| %>
                        <div class="input-group input-group-sm">
                          <%= f.number_field :quantity, value: item.quantity, min: 1, max: item.book.stock_quantity, class: "form-control" %>
                          <%= f.submit "Update", class: "btn btn-outline-dark btn-sm" %>
                        </div>
                      <% end %>
                    </td>
                    <td>$<%= number_with_precision(item.subtotal, precision: 2) %></td>
                    <td>
                      <%= button_to "✕", cart_item_path(item),
                          method: :delete,
                          class: "btn btn-danger btn-sm",
                          form: { data: { turbo_confirm: "Remove this item?" } } %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="mt-3">
          <%= link_to "← Continue Shopping", books_path, class: "btn btn-outline-dark" %>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Order Summary</h5>
            <hr>
            <div class="d-flex justify-content-between mb-2">
              <span>Items (<%= @cart.total_items %>)</span>
              <span>$<%= number_with_precision(@cart.total_price, precision: 2) %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span class="text-warning">$<%= number_with_precision(@cart.total_price, precision: 2) %></span>
            </div>
            <div class="d-grid mt-4">
              <%= link_to "Proceed to Checkout →", new_checkout_path, class: "btn btn-warning btn-lg" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>